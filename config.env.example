# ============================================================================
#  Copy this file to `config.env` (same folder, the repo root) and fill in your
#  own values. `config.env` is git-ignored, so your real IDs are never pushed.
#  The deploy and test scripts source it automatically.
# ============================================================================

# --- required identifiers ----------------------------------------------------
export SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000   # your Azure subscription ID
export TENANT_ID=00000000-0000-0000-0000-000000000000         # your Entra tenant ID
export GROUP_OID=00000000-0000-0000-0000-000000000000         # object ID of your "copilot-users" group
export LOCATION=eastus2                                        # any region with gpt-4.1 + APIM v2

# --- reference only (not consumed by scripts) --------------------------------
export PUBLISHER_EMAIL=you@example.com                         # APIM publisher contact (cosmetic)
export TEST_USER=copilotuser@yourtenant.onmicrosoft.com        # an in-group test user (device-code sign-in)
# export TEST_USER_PASSWORD=...                                # optional; MFA is still required

# Resource names are non-secret defaults baked into the scripts; override here if you want:
# export RG=rg-copilot-foundry-poc      SVC=apim-copilot-poc      FOUNDRY=cog-copilot-poc        # Option A
# export RG=rg-copilot-foundry-poc-pt   SVC=apim-copilot-poc-pt   FOUNDRY=cog-copilot-poc-pt     # Option B
