{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Publishes the Copilot per-developer FinOps Azure Monitor Workbook, bound to the Application Insights resource that holds the APIM token metrics."
  },
  "parameters": {
    "workbookDisplayName": {
      "type": "string",
      "defaultValue": "Copilot FinOps — per-developer usage & cost"
    },
    "workbookSourceId": {
      "type": "string",
      "metadata": { "description": "Resource id of the Application Insights component to bind the workbook to." }
    },
    "serializedData": {
      "type": "string",
      "metadata": { "description": "The serialized workbook content (finops/workbook.json with the resource id injected)." }
    }
  },
  "variables": {
    "workbookId": "[guid(resourceGroup().id, parameters('workbookDisplayName'))]"
  },
  "resources": [
    {
      "type": "microsoft.insights/workbooks",
      "apiVersion": "2022-04-01",
      "name": "[variables('workbookId')]",
      "location": "[resourceGroup().location]",
      "kind": "shared",
      "properties": {
        "displayName": "[parameters('workbookDisplayName')]",
        "serializedData": "[parameters('serializedData')]",
        "version": "1.0",
        "sourceId": "[parameters('workbookSourceId')]",
        "category": "workbook"
      }
    }
  ],
  "outputs": {
    "workbookResourceId": {
      "type": "string",
      "value": "[resourceId('microsoft.insights/workbooks', variables('workbookId'))]"
    }
  }
}
