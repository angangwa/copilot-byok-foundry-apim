<policies>
  <inbound>
    <base />
    <!-- ===================================================================
         PoC #2 — DEVELOPER-IDENTITY PASS-THROUGH
         The developer's own Entra token is forwarded UNCHANGED to Foundry.
         Authorization is enforced by Azure RBAC on the user GROUP at the
         Foundry resource; no-bypass is enforced by NETWORK (private Foundry,
         reachable only from APIM's subnet). Contrast with PoC #1, which
         swapped in APIM's managed-identity token and checked the group via
         Microsoft Graph. Here APIM keeps ONLY: token validation (fast-fail),
         per-user rate limit, and per-user metering.
         =================================================================== -->

    <!-- 1) Authenticate (defense-in-depth fast-fail): our tenant + cognitiveservices
         audience. Foundry re-validates the same token itself, but rejecting bad
         tokens here saves a backend round-trip and lets us read the oid. -->
    <validate-azure-ad-token tenant-id="{{tenant-id}}" output-token-variable-name="jwt"
        failed-validation-httpcode="401" failed-validation-error-message="Unauthorized.">
      <audiences>
        <audience>https://cognitiveservices.azure.com</audience>
      </audiences>
    </validate-azure-ad-token>
    <set-variable name="oid"
       value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;oid&quot;, new string[]{&quot;&quot;})[0])" />
    <!-- ⚠️ PII: developer display name from the 'name' claim (same extraction pattern as oid).
         Convenient for human-readable cost attribution in the FinOps dashboard, but it writes
         PERSONAL DATA into the metrics store (App Insights). In a regulated / FSI setting you may
         NOT want this — delete this set-variable AND the matching developerName dimension below to
         keep only the oid GUID, and resolve oid -> name at the dashboard layer instead.
         NOTE: in this pass-through variant Foundry's own diagnostic logs already record the real
         developer oid, so resolving name at the dashboard (not here) is usually the cleaner choice. -->
    <set-variable name="developerName"
       value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;name&quot;, new string[]{&quot;&quot;})[0])" />
    <!-- Capture the requested model for per-model metering. preserveContent=true keeps the
         body intact for the backend. For model-router this reads "model-router". -->
    <set-variable name="model"
       value="@{ var b = context.Request.Body?.As&lt;JObject&gt;(true); return (b != null &amp;&amp; b[&quot;model&quot;] != null) ? b[&quot;model&quot;].ToString() : &quot;unknown&quot;; }" />

    <!-- NOTE: no group check here. Group membership is enforced NATIVELY by Azure
         RBAC ("Cognitive Services OpenAI User" granted to the copilot-users group on
         the Foundry account) — a non-member's pass-through token gets 403 from Foundry. -->

    <!-- 2) Govern: per-developer TPM + metering keyed on the Entra oid -->
    <llm-token-limit counter-key="@(&quot;tpm-&quot; + (string)context.Variables[&quot;oid&quot;])"
       tokens-per-minute="50000" estimate-prompt-tokens="false"
       remaining-tokens-variable-name="remainingTokens" />
    <llm-emit-token-metric namespace="copilot">
      <dimension name="oid" value="@((string)context.Variables[&quot;oid&quot;])" />
      <dimension name="model" value="@((string)context.Variables[&quot;model&quot;])" />
      <dimension name="developerName" value="@((string)context.Variables[&quot;developerName&quot;])" /> <!-- ⚠️ PII — see note above -->
    </llm-emit-token-metric>

    <!-- 3) Forward to the PRIVATE Foundry data-plane endpoint — DATA-PLANE ONLY.
         We do NOT acquire/attach a managed-identity token and we do NOT touch the
         Authorization header, so the developer's original Bearer token passes through
         unchanged (APIM forwards Authorization by default). The host
         (cog-copilot-poc-pt.openai.azure.com) resolves to the private endpoint from
         APIM's integrated subnet via the linked privatelink.openai.azure.com zone.
         Both /chat/completions and /responses go to this one data-plane backend; a
         cognitiveservices-audience token cannot reach the ai.azure.com project endpoint,
         so model-router /responses is intentionally unsupported (named-model /responses works). -->
    <set-backend-service base-url="{{foundry-endpoint}}" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
