<policies>
  <inbound>
    <base />
    <!-- 1) Authenticate the developer: our tenant + cognitiveservices audience -->
    <validate-azure-ad-token tenant-id="{{tenant-id}}" output-token-variable-name="jwt"
        failed-validation-httpcode="401" failed-validation-error-message="Unauthorized.">
      <audiences>
        <audience>https://cognitiveservices.azure.com</audience>
      </audiences>
    </validate-azure-ad-token>
    <set-variable name="oid"
       value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;oid&quot;, new string[]{&quot;&quot;})[0])" />
    <!-- Capture the requested model for per-model metering. preserveContent=true keeps the
         body intact for the backend. For model-router this reads "model-router"; the actual
         routed model is in each response's "model" field. -->
    <set-variable name="model"
       value="@{ var b = context.Request.Body?.As&lt;JObject&gt;(true); return (b != null &amp;&amp; b[&quot;model&quot;] != null) ? b[&quot;model&quot;].ToString() : &quot;unknown&quot;; }" />

    <!-- 2) Authorize: is the developer a member of the allowed group? (cached per oid)
         We query the group's transitiveMembers filtered by the developer's oid (transitive =
         also matches members of nested groups). This authorizes with the GroupMember.Read.All
         application permission. NB: directoryObjects/{id}/checkMemberGroups would instead
         require Directory.Read.All. -->
    <cache-lookup-value key="@(&quot;grp-&quot; + (string)context.Variables[&quot;oid&quot;])" variable-name="inGroup" />
    <choose>
      <when condition="@(!context.Variables.ContainsKey(&quot;inGroup&quot;))">
        <authentication-managed-identity resource="https://graph.microsoft.com"
            output-token-variable-name="graphToken" />
        <send-request mode="new" response-variable-name="grp" timeout="10" ignore-error="false">
          <set-url>@($"https://graph.microsoft.com/v1.0/groups/{{copilot-allowed-group-id}}/transitiveMembers/microsoft.graph.user?$count=true&amp;$filter=id%20eq%20'{(string)context.Variables["oid"]}'&amp;$select=id")</set-url>
          <set-method>GET</set-method>
          <set-header name="Authorization" exists-action="override">
            <value>@("Bearer " + (string)context.Variables["graphToken"])</value>
          </set-header>
          <set-header name="ConsistencyLevel" exists-action="override">
            <value>eventual</value>
          </set-header>
        </send-request>
        <set-variable name="inGroup"
           value="@(((IResponse)context.Variables[&quot;grp&quot;]).Body.As&lt;JObject&gt;()[&quot;value&quot;].HasValues)" />
        <cache-store-value key="@(&quot;grp-&quot; + (string)context.Variables[&quot;oid&quot;])"
           value="@((bool)context.Variables[&quot;inGroup&quot;])" duration="3600" />
      </when>
    </choose>
    <choose>
      <when condition="@(!(bool)context.Variables[&quot;inGroup&quot;])">
        <return-response>
          <set-status code="403" reason="Forbidden" />
          <set-body>{"error":"Not a member of an authorized group."}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 3) Govern: per-developer TPM + metering keyed on Entra oid -->
    <llm-token-limit counter-key="@(&quot;tpm-v2-&quot; + (string)context.Variables[&quot;oid&quot;])"
       tokens-per-minute="50000" estimate-prompt-tokens="false"
       remaining-tokens-variable-name="remainingTokens" />
    <llm-emit-token-metric namespace="copilot">
      <dimension name="oid" value="@((string)context.Variables[&quot;oid&quot;])" />
      <dimension name="model" value="@((string)context.Variables[&quot;model&quot;])" />
    </llm-emit-token-metric>

    <!-- 4) Swap to APIM's managed identity and forward to Foundry — PATH-BASED routing.
         model-router serves its two APIs on two different Azure endpoints, so we route by path:
           * /responses        -> Foundry PROJECT endpoint, MI token audience https://ai.azure.com
           * everything else    -> classic data-plane endpoint, MI audience https://cognitiveservices.azure.com
         (named models work on both; only model-router is split — see the docs' two-tab example.)
         The developer always authenticates to APIM with a "cognitiveservices" token (validated
         above); only this backend hop's audience/endpoint differs by path. -->
    <choose>
      <when condition="@(context.Request.Url.Path.EndsWith(&quot;/responses&quot;, StringComparison.OrdinalIgnoreCase))">
        <authentication-managed-identity resource="https://ai.azure.com" output-token-variable-name="mi" />
        <set-backend-service base-url="{{foundry-project-endpoint}}" />
      </when>
      <otherwise>
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="mi" />
        <set-backend-service base-url="{{foundry-endpoint}}" />
      </otherwise>
    </choose>
    <set-header name="Authorization" exists-action="override">
      <value>@("Bearer " + (string)context.Variables["mi"])</value>
    </set-header>
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
